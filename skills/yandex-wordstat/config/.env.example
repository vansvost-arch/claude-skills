# Yandex Wordstat API credentials
# Register at: https://oauth.yandex.ru/client/new
# See config/README.md for instructions

# Required: OAuth token for Wordstat API
YANDEX_WORDSTAT_TOKEN=your_token_here

# Optional: for token refresh via get_token.sh
# YANDEX_CLIENT_ID=your_client_id
# YANDEX_CLIENT_SECRET=your_client_secret
